{
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json,subprocess;d=json.load(sys.stdin);proj=d.get('cwd','').rsplit('/',1)[-1];title=d.get('title','Claude Code');subprocess.run(['notify-send',f'Claude Code [{proj}]',d.get('message','Needs your attention')])\""
          }
        ]
      }
    ]
  }
}
